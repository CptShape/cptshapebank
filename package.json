{
  "name": "cpt-shape-bank",
  "version": "1.0.2",
  "description": "Personal finance tracker for Android, web, and Windows desktop.",
  "author": "CptShape",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "node scripts/run-android-local.cjs",
    "web": "expo start --web",
    "lint": "tsc --noEmit",
    "desktop:web": "expo export --platform web",
    "desktop": "npm run desktop:web && electron electron/main.cjs",
    "desktop:build": "npm run desktop:web && electron-builder --win nsis",
    "desktop:release": "npm run desktop:web && node scripts/run-desktop-release.cjs",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "electron-updater": "^6.6.2",
    "expo": "~54.0.34",
    "expo-asset": "~12.0.13",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "firebase": "^11.10.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "babel-preset-expo": "~54.0.10",
    "typescript": "~5.9.2"
  },
  "build": {
    "appId": "com.cptshapebank.desktop",
    "productName": "CptShapeBank",
    "directories": {
      "output": "desktop-release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "publish": {
      "provider": "github",
      "owner": "CptShape",
      "repo": "cptshapebank",
      "releaseType": "release"
    },
    "win": {
      "signAndEditExecutable": false,
      "artifactName": "CptShapeBank-Setup-${version}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true
    }
  }
}
